      },
      "transportUnits": {
        "title": "Přepravní jednotky",
        "desc": "Definice typů přepravovaného zboží (palety, kartony apod.). Každá jednotka má výchozí váhu obalu a dobu zpracování v minutách.",
        "tip": "Příklad: 'Paleta EUR' — váha obalu 25 kg, zpracování 5 minut."
      },
