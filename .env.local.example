# PostgreSQL connection — adjust user/password/host to your local setup
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timeslotcontrol"

# Auth.js secret — any random string for local dev
AUTH_SECRET="dev-secret-change-in-production"

# Optional: Resend API key for email notifications (leave empty to skip emails)
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="noreply@dockscheduling.com"
