generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum UserRole {
  ADMIN
  WAREHOUSE_WORKER
  CLIENT
  SUPPLIER

  @@map("user_role")
}

enum ReservationStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  UNLOADING_STARTED
  UNLOADING_COMPLETED
  CLOSED

  @@map("reservation_status")
}

enum VehicleType {
  TRUCK
  VAN
  TRUCK_DOUBLE_TRAILER
  TRUCK_CURTAINSIDER
  REFRIGERATED_TRUCK
  OTHER

  @@map("vehicle_type")
}

enum NotificationType {
  RESERVATION_CREATED
  RESERVATION_APPROVED
  RESERVATION_REJECTED
  STATUS_CHANGED
  CHANGE_REQUESTED

  @@map("notification_type")
}

// TransportUnitType enum removed — replaced by TransportUnit model

// ─────────────────────────────────────────
// Warehouse & Gate
// ─────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  timezone  String   @default("Europe/Prague")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gates Gates[]
  users UserWarehouse[]

  @@map("warehouse")
}

model Gates {
  id          String   @id @default(cuid())
  warehouseId String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  openingHours GateOpeningHours[]
  reservations Reservation[]

  @@map("gate")
}

model GateOpeningHours {
  id        String  @id @default(cuid())
  gateId    String
  dayOfWeek Int // 0 = Sunday … 6 = Saturday
  openTime  String // "HH:MM"
  closeTime String // "HH:MM"
  isOpen    Boolean @default(true)

  gate Gates @relation(fields: [gateId], references: [id], onDelete: Cascade)

  @@unique([gateId, dayOfWeek])
  @@map("gate_opening_hours")
}

// ─────────────────────────────────────────
// Transport Units
// ─────────────────────────────────────────

model TransportUnit {
  id                String   @id @default(cuid())
  name              String   @unique
  weightKg          Decimal  @default(0) @db.Decimal(10, 2)
  processingMinutes Int      @default(0)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reservationItems ReservationItem[]

  @@map("transport_unit")
}

// ─────────────────────────────────────────
// Client & Supplier (M:N)
// ─────────────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  name         String
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  suppliers    ClientSupplier[]
  reservations Reservation[]
  users        User[]

  @@map("client")
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients      ClientSupplier[]
  reservations Reservation[]
  users        User[]

  @@map("supplier")
}

model ClientSupplier {
  clientId   String
  supplierId String

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([clientId, supplierId])
  @@map("client_supplier")
}

// ─────────────────────────────────────────
// Reservation (with versioning)
// ─────────────────────────────────────────

model Reservation {
  id                 String            @id @default(cuid())
  gateId             String
  clientId           String
  supplierId         String
  status             ReservationStatus @default(REQUESTED)
  confirmedVersionId String?           @unique
  pendingVersionId   String?           @unique
  createdById        String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  gate             Gates               @relation(fields: [gateId], references: [id], onDelete: Restrict)
  client           Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  supplier         Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy        User                @relation("ReservationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  confirmedVersion ReservationVersion? @relation("ConfirmedVersion", fields: [confirmedVersionId], references: [id], onDelete: SetNull)
  pendingVersion   ReservationVersion? @relation("PendingVersion", fields: [pendingVersionId], references: [id], onDelete: SetNull)
  versions         ReservationVersion[] @relation("AllVersions")
  notifications    Notification[]
  statusChanges    ReservationStatusChange[]

  @@index([gateId])
  @@index([clientId])
  @@index([supplierId])
  @@index([status])
  @@map("reservation")
}

model ReservationStatusChange {
  id            String            @id @default(cuid())
  reservationId String
  status        ReservationStatus
  changedAt     DateTime          @default(now())
  changedById   String

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  changedBy   User        @relation("StatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([reservationId])
  @@map("reservation_status_change")
}

model ReservationVersion {
  id              String      @id @default(cuid())
  reservationId   String
  startTime       DateTime
  durationMinutes Int // multiples of 15
  vehicleType     VehicleType
  licensePlate    String?
  sealNumbers     String?
  driverName      String?
  driverContact   String?
  notes           String?
  createdById     String
  createdAt       DateTime    @default(now())

  reservation           Reservation  @relation("AllVersions", fields: [reservationId], references: [id], onDelete: Cascade)
  confirmedByReservation Reservation? @relation("ConfirmedVersion")
  pendingByReservation   Reservation? @relation("PendingVersion")
  createdBy             User         @relation("VersionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items                 ReservationItem[]

  @@index([reservationId])
  @@index([startTime])
  @@map("reservation_version")
}

model ReservationItem {
  id                   String  @id @default(cuid())
  reservationVersionId String
  transportUnitId      String
  quantity             Int
  goodsWeightKg        Decimal? @db.Decimal(10, 2)
  description          String?

  transportUnit      TransportUnit      @relation(fields: [transportUnitId], references: [id], onDelete: Restrict)
  reservationVersion ReservationVersion @relation(fields: [reservationVersionId], references: [id], onDelete: Cascade)

  @@map("reservation_item")
}

// ─────────────────────────────────────────
// Audit Log
// ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String // "reservation" | "gate" | "user" | ...
  entityId   String
  action     String // "created" | "status_changed" | "version_approved" | ...
  oldData    Json?
  newData    Json?
  userId     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

// ─────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  reservationId String?
  title         String
  message       String
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notification")
}

// ─────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  password    String
  role        UserRole
  clientId    String? // only for CLIENT
  supplierId  String? // only for SUPPLIER
  isActive      Boolean   @default(true)
  notifyInApp   Boolean   @default(true)
  notifyBrowser Boolean   @default(false)
  notifyEmail   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  warehouses UserWarehouse[]
  client     Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  supplier   Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  reservationsCreated Reservation[]        @relation("ReservationCreatedBy")
  versionsCreated     ReservationVersion[] @relation("VersionCreatedBy")
  auditLogs           AuditLog[]
  notifications       Notification[]
  statusChanges       ReservationStatusChange[] @relation("StatusChangedBy")

  @@map("user")
}

model UserWarehouse {
  userId      String
  warehouseId String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([userId, warehouseId])
  @@map("user_warehouse")
}
