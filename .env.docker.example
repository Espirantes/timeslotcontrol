# Copy to .env.docker and fill in values before running docker compose
DATABASE_URL=postgresql://postgres:postgres@db:5432/timeslotcontrol

# Auth.js v5 — required
AUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-to-a-random-32-char-string

# Optional — email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
